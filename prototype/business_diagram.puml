@startuml Business
title ArchiMate Business Layer View
!include <archimate/archimate>
' skinparam linetype ortho

Business_Event(event_change_request, 'Business Idea / Change Request')
Business_Object(object_business_value, 'Business Outcome / Customer Value')
Business_Object(object_executable_spec, 'Executable Specification')
Business_Object(object_regulation, 'Regulation / Policy / Controls')
Business_Object(object_strategic_intent, 'Strategic & Architectural Intent')
Business_Object(object_technical_backlog, 'Technical Backlog / Future Work')
Business_Process(process_agentic_crew, 'Agentic Crew')
Business_Process(process_release, 'Production Release')
Business_Process(process_spec_generation, 'Deterministic Spec Generation')
Business_Process(process_state_discovery, 'Current State Discovery')
Business_Role(role_ba, 'Business Analyst')
Business_Role(role_code_quality, 'Code Quality')
Business_Role(role_debt_analyst, 'Debt Analyst')
Business_Role(role_dev, 'Developer')
Business_Role(role_devops, 'DevOps / Release')
Business_Role(role_refactoring, 'Refactoring')
Business_Role(role_sa, 'Solution Architect')
Business_Role(role_sec_comp, 'Security & Compliance')
Business_Role(role_te, 'Test Engineer')
Strategy_Capability(cap_control_plane, 'Agentic Supervisory Control')
Strategy_Capability(cap_digital_twin, 'Digital Twin Knowledge Graph')
Strategy_Capability(cap_drift_dashboard, 'Architectural Drift Detection & Reconciliation')
Strategy_Capability(cap_forensic_ledger, 'Forensic Audit & Compliance Ledger')
Strategy_Capability(cap_human_approval_workflow, 'Human Oversight & Approval Workflow')
Strategy_Capability(cap_spec_engine, 'Executable Specification Generation')

Rel_Access(process_agentic_crew, object_executable_spec)
Rel_Access(process_agentic_crew, object_regulation)
Rel_Access(process_spec_generation, object_strategic_intent)
Rel_Access(process_spec_generation, object_technical_backlog)
Rel_Access(process_spec_generation, object_executable_spec)
Rel_Access(process_state_discovery, object_technical_backlog)
Rel_Assignment(role_ba, event_change_request, 'defines requirements for')
Rel_Assignment(role_code_quality, process_release, 'gates quality for')
Rel_Assignment(role_debt_analyst, process_state_discovery, 'identifies gaps via')
Rel_Assignment(role_dev, process_agentic_crew, 'manages delivery aspects of')
Rel_Assignment(role_devops, process_release, 'executes')
Rel_Assignment(role_refactoring, process_state_discovery, 'simplifies code via')
Rel_Assignment(role_sa, process_spec_generation, 'provides design input for')
Rel_Assignment(role_sec_comp, process_spec_generation, 'defines security requirements for')
Rel_Assignment(role_sec_comp, process_agentic_crew, 'oversees compliance in')
Rel_Assignment(role_sec_comp, process_state_discovery, 'analyzes compliance via')
Rel_Assignment(role_te, process_agentic_crew, 'manages quality aspects of')
Rel_Flow(process_spec_generation, process_agentic_crew, 'produces specification for')
Rel_Realization_Up(process_agentic_crew, cap_control_plane, 'realizes')
Rel_Realization_Up(process_release, object_business_value, 'delivers')
Rel_Realization_Up(process_release, cap_forensic_ledger, 'audited by')
Rel_Realization_Up(process_spec_generation, cap_spec_engine, 'realizes')
Rel_Realization_Up(process_spec_generation, cap_digital_twin, 'consumes')
Rel_Realization_Up(process_state_discovery, cap_drift_dashboard, 'realizes')
Rel_Realization_Up(process_state_discovery, cap_digital_twin, 'updates')
Rel_Realization_Up(role_sa, cap_human_approval_workflow, 'accountable approver')
Rel_Realization_Up(role_sec_comp, cap_human_approval_workflow, 'compliance sign-off')
Rel_Triggering(event_change_request, process_spec_generation, 'initiates')
Rel_Triggering(process_agentic_crew, process_release, 'governs & triggers')
Rel_Triggering(process_release, process_state_discovery, 'runs system for')

@enduml