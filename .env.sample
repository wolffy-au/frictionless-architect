# Environment configuration for frictionless-architect
# Copy this file to `.env` and adjust values before running the application or schema scripts.

# Core application settings
FRICTIONLESS_ARCHITECT_DATABASE_URL=sqlite:///./frictionless_architect.db
FRICTIONLESS_ARCHITECT_DATABASE_ECHO=false
FRICTIONLESS_ARCHITECT_LOG_LEVEL=INFO

# Security / auth placeholders
FRICTIONLESS_ARCHITECT_SECURITY_ENABLED=false
FRICTIONLESS_ARCHITECT_JWT_SECRET=changeme
FRICTIONLESS_ARCHITECT_JWT_ALGORITHM=HS256
FRICTIONLESS_ARCHITECT_ENCRYPTION_KEY=changeme

# Neo4j schema bootstrap (used by `scripts/neo4j_schema.py`)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
